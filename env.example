# ══════════════════════════════════════
#  TRADING BOT — Configuration secrète
#  Renomme ce fichier en .env
# ══════════════════════════════════════

# Exchange Binance Testnet
# Clés générées sur testnet.binance.vision
API_KEY=ta_clé_api_ici
API_SECRET=ton_secret_ici

# Paper trading activé par défaut (true = argent fictif)
DRY_RUN=true

# Capital de départ (fictif sur testnet)
INITIAL_CAPITAL=1000

# Telegram (optionnel — pour recevoir les alertes)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# News API (optionnel)
NEWS_API_KEY=

# Logs
LOG_LEVEL=INFO
